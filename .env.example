# ============================================
# SISTEMA DE ANÁLISE DE SENTIMENTOS - CONFIGURAÇÃO
# ============================================

# --------------------------------------------
# APIs de LLM (Large Language Models)
# --------------------------------------------
# OpenAI API (GPT-4, GPT-3.5-turbo)
OPENAI_API_KEY=sua_cha_aqui
OPENAI_API_BASE=https://api.openai.com/v1

# Groq API (Llama, Mixtral)
GROQ_API_KEY=sua_cha_aqui

# Hugging Face API
HUGGINGFACE_API_KEY=sua_cha_aqui

# --------------------------------------------
# Coleta de Dados
# --------------------------------------------
# Twitter/X API v2
TWITTER_BEARER_TOKEN=seu_token_aqui
TWITTER_API_KEY=sua_cha_aqui
TWITTER_API_SECRET=seu_secreto_aqui

# Google Reviews API
GOOGLE_API_KEY=sua_cha_aqui
GOOGLE_CX=seu_cx_aqui

# --------------------------------------------
# Banco de Dados
# --------------------------------------------
DATABASE_URL=postgresql://usuario:senha@localhost:5432/sentimentos_db

# SQLite para desenvolvimento
# DATABASE_URL=sqlite:///./sentimentos.db

# --------------------------------------------
# Redis (Cache e Celery)
# --------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --------------------------------------------
# Configurações da API
# --------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
SECRET_KEY=gerar_uma_chave_secreta_aleatoria_aqui

# JWT para autenticação
JWT_SECRET_KEY=chave_secreta_jwt_aqui
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --------------------------------------------
# Configurações de Modelos
# --------------------------------------------
# Modelo padrão para análise
DEFAULT_MODEL=bertabaporu-dimensional

#Cache de modelos
USE_MODEL_CACHE=true
MODEL_CACHE_DIR=./models/cache

# Quantização para economizar memória
USE_QUANTIZATION=false

# --------------------------------------------
# Processamento
# --------------------------------------------
MAX_BATCH_SIZE=100
MAX_TEXT_LENGTH=512
ENABLE_ASYNC_PROCESSING=true

# --------------------------------------------
# Logging
# --------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=./logs/sistema.log

# --------------------------------------------
# Dashboard
# --------------------------------------------
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8050